# llama.cpp local server only. Cloud LLM/API keys are intentionally unsupported.
ORACLE_LLM_BASE_URL=http://127.0.0.1:8080/v1
ORACLE_LLM_MODEL=local-model
ORACLE_LLM_SEND_IMAGE=0
ORACLE_LLM_PROMPT_CACHE=0

# Flask UI defaults.
ORACLE_APP_HOST=0.0.0.0
ORACLE_APP_PORT=8501
ORACLE_APP_DEBUG=0

# Role-specific local LLM settings.
ORACLE_FACE_LLM_BASE_URL=http://127.0.0.1:8080/v1
ORACLE_FACE_LLM_MODEL=local-model
ORACLE_FACE_LLM_SEND_IMAGE=0
ORACLE_FACE_LLM_MAX_OUTPUT_TOKENS=4096
ORACLE_REPORT_LLM_BASE_URL=http://127.0.0.1:8080/v1
ORACLE_REPORT_LLM_MODEL=local-model
ORACLE_REPORT_LLM_SEND_IMAGE=0
ORACLE_REPORT_LLM_TIMEOUT_SECONDS=3600
ORACLE_REPORT_LLM_MAX_OUTPUT_TOKENS=4096
ORACLE_LLM_TIMEOUT_SECONDS=120

# Change these three values to use a different GGUF model.
ORACLE_START_LLAMA_SERVER=1
ORACLE_LLAMA_MODEL_PATH=models/gemma-4-E2B-it-UD-Q2_K_XL.gguf
ORACLE_LLAMA_MODEL_URL=https://huggingface.co/unsloth/gemma-4-E2B-it-GGUF/resolve/main/gemma-4-E2B-it-UD-Q2_K_XL.gguf
ORACLE_LLAMA_MODEL_SHA256=dd279a54c0c0dc9724ed11d7f73ad7fb4489a45f58fefe9447da2429a727de0c
ORACLE_LLAMA_SERVER_BIN=llama-server
LLAMA_CONTEXT_SIZE=8192

# Camera defaults for Raspberry Pi or USB camera.
ORACLE_CAMERA_INDEX=0
ORACLE_FRAME_WIDTH=640
ORACLE_FRAME_HEIGHT=480
ORACLE_CAMERA_FPS=15
ORACLE_MIN_FACE_SECONDS=2.0
ORACLE_FACE_MIN_SIZE_PX=96
ORACLE_FACE_DETECTION_SCALE=0.5
ORACLE_FACE_DETECTION_INTERVAL=2
ORACLE_SHOW_PREVIEW=1
ORACLE_FACE_ANALYSIS_MODE=2
ORACLE_HAAR_CASCADE_DIR=/usr/share/opencv4/haarcascades

# Capture quality thresholds.
ORACLE_EYE_MIN_COUNT=2
ORACLE_EYEBROW_MIN_EDGE_DENSITY=0.018

# Report output.
ORACLE_OUTPUT_DIR=runs
ORACLE_PROMPTS_PATH=configs/prompts.json
ORACLE_DEBUG_PROMPTS_PATH=configs/prompts_debug.json
ORACLE_FACE_DB_PATH=data/face_recommendations.sqlite
