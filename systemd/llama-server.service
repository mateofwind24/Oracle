[Unit]
Description=llama.cpp local LLM server
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/home/hyukju/oracle
Environment=LLAMA_MODEL=/home/hyukju/oracle/models/gemma-3-1b-it-Q4_0.gguf
ExecStart=/home/hyukju/oracle/scripts/run_llama_server.sh ${LLAMA_MODEL}
Restart=on-failure
RestartSec=5
User=hyukju

[Install]
WantedBy=multi-user.target
